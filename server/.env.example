# Copy this file to server/.env and fill in real values before running.

# REQUIRED — a long, random secret. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_secret

# Optional — override default credentials (admin / element)
# AUTH_USERNAME=admin
# AUTH_PASSWORD=element

# Optional — port for the auth server (default: 4000)
# PORT=4000

# Optional — allowed client origin for CORS (default: http://localhost:5173)
# CLIENT_ORIGIN=http://localhost:5173
