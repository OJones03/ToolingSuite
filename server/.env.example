# JWT_SECRET must be set to a long, random string before starting the server.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-string

# Optional: override credentials (defaults are admin / password123)
# AUTH_USERNAME=admin
# AUTH_PASSWORD=password123

# Optional: override the default port (4001)
# PORT=4001
